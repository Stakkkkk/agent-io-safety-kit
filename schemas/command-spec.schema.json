{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stakkkkk.github.io/agent-io-safety-kit/schemas/command-spec.schema.json",
  "title": "Agent I/O Safety command spec",
  "description": "Structured command execution spec for safe-shell-io/scripts/run-from-spec.mjs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["command"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional schema URL for editor validation."
    },
    "command": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "\\u0000"
      },
      "description": "Executable command or program path. Shell built-ins are not portable."
    },
    "args": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string",
        "not": {
          "pattern": "\\u0000"
        }
      },
      "description": "Arguments passed as exact argv items without shell parsing."
    },
    "cwd": {
      "type": "string",
      "minLength": 1,
      "default": ".",
      "not": {
        "pattern": "\\u0000"
      },
      "description": "Working directory. Relative paths are resolved from the spec file directory."
    },
    "env": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string",
            "not": {
              "pattern": "\\u0000"
            }
          },
          {
            "type": "null"
          }
        ]
      },
      "description": "Environment overrides. String sets a variable; null removes it."
    },
    "stdin": {
      "type": "string",
      "not": {
        "pattern": "\\u0000"
      },
      "description": "UTF-8 string passed to stdin."
    },
    "stdinFile": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "\\u0000"
      },
      "description": "File whose bytes are passed to stdin. Mutually exclusive with stdin."
    },
    "stdoutEncoding": {
      "$ref": "#/$defs/outputEncoding"
    },
    "stderrEncoding": {
      "$ref": "#/$defs/outputEncoding"
    },
    "stdoutFile": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "\\u0000"
      },
      "description": "File for normalized stdout. Relative paths are resolved from cwd."
    },
    "stderrFile": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "\\u0000"
      },
      "description": "File for normalized stderr. Relative paths are resolved from cwd."
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 1,
      "default": 30000
    },
    "maxOutputBytes": {
      "type": "integer",
      "minimum": 1,
      "default": 16777216
    }
  },
  "allOf": [
    {
      "not": {
        "required": ["stdin", "stdinFile"]
      }
    }
  ],
  "$defs": {
    "outputEncoding": {
      "type": "string",
      "minLength": 1,
      "default": "utf8",
      "description": "TextDecoder encoding label or raw. raw disables decoding.",
      "examples": ["utf8", "utf-8", "utf-16le", "raw"]
    }
  }
}
