{
  "name": "agent-io-safety-kit",
  "version": "0.1.4",
  "description": "Portable rules, skills, and scripts for safer agent shell and text I/O.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "ai-agents",
    "agents",
    "shell",
    "argv",
    "encoding",
    "utf8",
    "bom",
    "powershell",
    "developer-tools"
  ],
  "homepage": "https://github.com/Stakkkkk/agent-io-safety-kit#readme",
  "bugs": {
    "url": "https://github.com/Stakkkkk/agent-io-safety-kit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Stakkkkk/agent-io-safety-kit.git"
  },
  "scripts": {
    "test": "node tests/run-tests.mjs",
    "check:text": "node skills/safe-text-io/scripts/inspect-text.mjs --all-files --fail-on-bom --eol lf --ps51-safe .",
    "doctor": "node scripts/doctor.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "release:notes": "node scripts/release-notes.mjs"
  },
  "bin": {
    "agent-io-safety-kit": "scripts/deploy.mjs",
    "agent-io-safety-deploy": "scripts/deploy.mjs",
    "agent-io-safety-doctor": "scripts/doctor.mjs",
    "safe-shell-run": "skills/safe-shell-io/scripts/run-from-spec.mjs",
    "safe-text-inspect": "skills/safe-text-io/scripts/inspect-text.mjs",
    "safe-text-replace-ascii-bytes": "skills/safe-text-io/scripts/replace-ascii-bytes.mjs",
    "safe-text-transcode": "skills/safe-text-io/scripts/transcode-text.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "00-MECHANISM.md",
    "00-MECHANISM.ru.md",
    "01-DEPLOYMENT.md",
    "01-DEPLOYMENT.ru.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "README.ru.md",
    "RULE.md",
    "RULE.ru.md",
    "SECURITY.md",
    "VERSION",
    "docs/",
    "examples/",
    "recipes/",
    "schemas/",
    "scripts/",
    "skills/",
    "snippets/"
  ],
  "publishConfig": {
    "access": "public"
  }
}
